# ═══════════════════════════════════════════════════
# Raabta Task Manager — Environment Variables
# ═══════════════════════════════════════════════════
# Is file ko `.env` ke naam se copy karo aur values bharo
# IMPORTANT: .env file kabhi GitHub push mat karo!

# ── Google Sheets (Database) ─────────────────────────
# Your Google Spreadsheet ID (URL mein /d/ ke baad wala part)
SHEET_ID=your_google_spreadsheet_id_here

# Google Service Account credentials (Vercel ke liye):
# credentials.json ka poora content JSON string mein paste karo
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# ── App ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SESSION_SECRET=change_this_to_a_very_long_random_string_here

# ── Email Automation (Gmail SMTP) ────────────────────
# 1. Gmail mein 2-Step Verification ON karo
# 2. https://myaccount.google.com/apppasswords se App Password banao
# 3. 16-character password (without spaces) yahan paste karo
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_FROM_NAME=Raabta Task Manager

# Aapke deployed app ka URL (email + WhatsApp links ke liye)
APP_URL=https://your-vercel-domain.vercel.app

# ── WhatsApp Automation (Aumpfy custom API) ──────────
# Task assign hote hi + roz reminder us user ke WhatsApp par jayega.
# Number Users list ke "phone" field se aata hai (10-digit ya country code ke saath).
WHATSAPP_ENABLED=true
AUMPFY_API_URL=https://api.aumpfy.com/api/apis/trigger/your-trigger-slug
AUMPFY_API_KEY=sl_your_api_key_here
# Default country code jab number 10-digit ho (India = 91)
WHATSAPP_COUNTRY_CODE=91
# Daily reminder kis hour par bheje (24h, server time). 10 = 10:00 AM
WHATSAPP_REMINDER_HOUR=10
